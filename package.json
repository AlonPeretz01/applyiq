{
  "name": "applyiq",
  "version": "1.0.0",
  "description": "Full-stack job application tracker",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"SERVER,CLIENT\" --prefix-colors \"cyan,magenta\" \"npm run server\" \"npm run client\"",
    "server": "npm --prefix server run dev",
    "client": "npm --prefix client run dev",
    "install:all": "npm install && npm --prefix server install && npm --prefix client install",
    "prisma:generate": "npm --prefix server run prisma:generate",
    "prisma:migrate": "npm --prefix server run prisma:migrate",
    "prisma:studio": "npm --prefix server run prisma:studio"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
