// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TargetType {
  FULLSTACK
  BACKEND
  DATA
  STUDENT
}

enum ApplicationStatus {
  DRAFT
  READY
  APPLIED
  OA
  INTERVIEW
  REJECTED
  OFFER
  WITHDRAWN
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Job {
  id           String   @id @default(cuid())
  company_name String
  title        String
  description  String?  @db.Text
  url          String?
  source       String?
  created_at   DateTime @default(now())

  applications  Application[]
  cover_letters CoverLetter[]
  ai_analyses   AiAnalysis[]

  @@map("jobs")
}

model CvVersion {
  id          String     @id @default(cuid())
  name        String
  target_type TargetType
  file_url    String?
  plain_text  String?    @db.Text
  created_at  DateTime   @default(now())

  applications Application[]

  @@map("cv_versions")
}

model CoverLetter {
  id         String   @id @default(cuid())
  job_id     String
  content    String   @db.Text
  created_at DateTime @default(now())

  job          Job          @relation(fields: [job_id], references: [id], onDelete: Cascade)
  applications Application[]

  @@map("cover_letters")
}

model Application {
  id              String            @id @default(cuid())
  job_id          String
  cv_version_id   String
  cover_letter_id String?
  applied_at      DateTime?
  status          ApplicationStatus @default(DRAFT)
  match_score     Float?
  notes           String?           @db.Text
  updated_at      DateTime          @updatedAt

  job          Job          @relation(fields: [job_id], references: [id], onDelete: Cascade)
  cv_version   CvVersion    @relation(fields: [cv_version_id], references: [id])
  cover_letter CoverLetter? @relation(fields: [cover_letter_id], references: [id])

  status_history StatusHistory[]

  @@map("applications")
}

model AiAnalysis {
  id                String   @id @default(cuid())
  job_id            String
  required_skills   String[]
  technologies      String[]
  experience_years  Int?
  job_type          String?
  seniority         String?
  keywords          String[]
  summary           String?  @db.Text
  match_tips        String[]
  recommended_cv_id String?
  match_score       Int?
  reason            String?  @db.Text
  suggested_tweaks  String[]
  created_at        DateTime @default(now())

  job Job @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@map("ai_analyses")
}

model StatusHistory {
  id             String            @id @default(cuid())
  application_id String
  old_status     ApplicationStatus?
  new_status     ApplicationStatus
  changed_at     DateTime          @default(now())
  note           String?

  application Application @relation(fields: [application_id], references: [id], onDelete: Cascade)

  @@map("status_history")
}
