# Database (Supabase PostgreSQL connection string)
# Use the "Transaction" connection string from Supabase > Settings > Database
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Use the "Session" connection string for Prisma migrations (direct connection)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase project credentials (Settings > API)
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_ANON_KEY="your-anon-key-here"

# OpenAI (for CV matching and cover letter generation)
OPENAI_API_KEY="sk-..."

# Server
PORT=3001
